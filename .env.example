# ─────────────────────────────────────────
# ColdWatch — Environment Variables Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────

# ── MySQL ──────────────────────────────────
MYSQL_ROOT_PASSWORD=your_root_password_here
DB_HOST=mysql
DB_USER=coldwatch
DB_PASSWORD=your_db_password_here
DB_NAME=coldwatch

# ── AWS SNS (for email alerts) ─────────────
# Get these from AWS Console → IAM → Your User → Security credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-southeast-1

# Get this from AWS Console → SNS → Topics → your topic → ARN
SNS_TOPIC_ARN=arn:aws:sns:ap-southeast-1:123456789012:your-topic-name

# ── Flask ──────────────────────────────────
# Set to "true" for local development, "false" for production
FLASK_DEBUG=false
